exports[`CngxStepper classic-skin CSS baseline > dark mode: which @media (prefers-color-scheme: dark) rules ship 1`] = `
{
  "stepper-base.css": [],
  "stepper.component.css": [
    "@media (prefers-color-scheme: dark) { :where(:root:not([data-color-scheme='light']):not(.light)) .cngx-stepper[data-skin='pill-segment'] { --cngx-step-pill-segment-rail-bg: oklch(0.24 0.005 240); --cngx-step-pill-segment-fill-active: oklch(0.4 0.008 240); --cngx-step-indicator-active-color: oklch(0.98 0 0); --cngx-step-pill-segment-card-shadow: 0 1px 2px color-mix(in srgb, oklch(0 0 0) 55%, transparent); }",
  ],
}
`;

exports[`CngxStepper classic-skin CSS baseline > light mode: declared initial-values for hot-state custom properties 1`] = `
{
  "--cngx-step-active-color": "<absent>",
  "--cngx-step-active-fill": "oklch(0.66 0.19 50)",
  "--cngx-step-completed-color": "oklch(0.5 0.15 145)",
  "--cngx-step-errored-color": "oklch(0.45 0.15 25)",
  "--cngx-step-focus-offset": "3px",
  "--cngx-step-focus-ring": "2px solid oklch(0.66 0.19 50)",
  "--cngx-step-hover-bg": "color-mix(in srgb, currentColor 8%, transparent)",
  "--cngx-step-indicator-active-color": "oklch(1 0 0)",
  "--cngx-step-indicator-bg": "color-mix(in srgb, currentColor 10%, transparent)",
  "--cngx-step-indicator-color": "currentColor",
  "--cngx-step-pending-color": "<absent>",
}
`;

exports[`CngxStepper classic-skin CSS baseline > light mode: rule bodies for the four hot states 1`] = `
{
  "active": ".cngx-stepper__step[aria-current='step'] .cngx-stepper__indicator { background: var(--cngx-step-active-color, var(--cngx-step-active-fill)); color: var(--cngx-step-indicator-active-color, oklch(1 0 0)); }",
  "completed": ".cngx-stepper__indicator[data-state='success'] { background: var(--cngx-step-completed-color, var(--cngx-color-success, oklch(0.5 0.15 145))); color: var(--cngx-step-indicator-active-color, oklch(1 0 0)); }",
  "errored": ".cngx-stepper__indicator[data-state='error'] { background: transparent; color: var(--cngx-step-errored-color, var(--cngx-color-danger, oklch(0.45 0.15 25))); box-shadow: inset 0 0 0 1px var(--cngx-step-errored-color, var(--cngx-color-danger, oklch(0.45 0.15 25))); }",
  "focusVisible": ".cngx-stepper__step:focus-visible { outline: var(--cngx-step-focus-ring, 2px solid currentColor); outline-offset: var(--cngx-step-focus-offset, 3px); }",
  "hover": ".cngx-stepper__step:hover:not([aria-disabled='true']) { background: var(--cngx-step-hover-bg, color-mix(in srgb, currentColor 8%, transparent)); cursor: pointer; }",
  "resting": ".cngx-stepper__indicator { position: relative; background: var(--cngx-step-indicator-bg, color-mix(in srgb, currentColor 10%, transparent)); color: var(--cngx-step-indicator-color, currentColor); font-size: var(--cngx-step-indicator-font-size, 0.85em); font-weight: var(--cngx-step-indicator-font-weight, 600); transition: background-color 120ms ease; }",
}
`;
