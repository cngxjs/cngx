{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "types": [],
    "paths": {
      "@cngx/core": ["dist/core/types/cngx-core.d.ts"],
      "@cngx/core/utils": ["dist/core/types/cngx-core-utils.d.ts"],
      "@cngx/common": ["dist/common/types/cngx-common.d.ts"],
      "@cngx/utils": ["dist/utils/types/cngx-utils.d.ts"],
      "@cngx/data-display/treetable": ["projects/data-display/treetable/public-api.ts"]
    }
  },
  "include": ["*.ts", "treetable/**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
