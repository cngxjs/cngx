/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "types": [],
    "paths": {
      "@cngx/core": ["dist/core/types/cngx-core.d.ts"],
      "@cngx/core/utils": ["dist/core/types/cngx-core-utils.d.ts"],
      "@cngx/utils": ["dist/utils/types/cngx-utils.d.ts"],
      "@cngx/common/interactive": ["dist/common/types/cngx-common-interactive.d.ts"],
      "@cngx/common/a11y": ["dist/common/types/cngx-common-a11y.d.ts"],
      "@cngx/forms/field": ["projects/forms/field/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "controls/**/*.ts", "validators/**/*.ts", "field/**/*.ts", "input/**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
