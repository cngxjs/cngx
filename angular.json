          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/data-display/**/*.ts",
              "projects/data-display/**/*.html"
            ]
          }
        }
      }
    }
  }
}