{
  "name": "cngx-src",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "prestart": "npm run docs:json",
    "start": "ng serve dev-app",
    "prebuild": "npm run docs:json",
    "build": "ng build dev-app",
    "build:libs": "ng build utils && ng build core && ng build common && ng build forms && ng build data-display && ng build ui",
    "build:utils": "ng build utils",
    "build:core": "ng build core",
    "build:forms": "ng build forms",
    "build:ui": "ng build ui",
    "build:common": "ng build common",
    "build:data-display": "ng build data-display",
    "build:dev-app": "ng build dev-app",
    "watch": "ng build dev-app --watch --configuration development",
    "test": "ng test utils --watch=false && ng test core --watch=false && ng test forms --watch=false && ng test ui --watch=false && ng test common --watch=false && ng test data-display --watch=false",
    "test:watch": "ng test utils",
    "test:utils": "ng test utils",
    "test:data-display": "ng test data-display",
    "test:common": "ng test common",
    "test:core": "ng test core",
    "test:forms": "ng test forms",
    "test:ui": "ng test ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write \"projects/**/src/**/*.{ts,html,scss}\" --ignore-pattern \"**/*.spec.ts\"",
    "docs": "rm -rf docs && compodocx",
    "docs:serve": "compodocx -s",
    "docs:watch": "compodocx -s -w",
    "docs:json": "compodocx -e json -d .compodoc",
    "demo:generate": "node scripts/generate-demos.mjs",
    "demo:new": "node scripts/new-demo.mjs",
    "demo:enrich": "node scripts/enrich-demo.mjs",
    "test:scripts": "vitest run --config scripts/vitest.config.mjs",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "publish:patch": "node scripts/publish.mjs --bump patch",
    "publish:minor": "node scripts/publish.mjs --bump minor",
    "publish:major": "node scripts/publish.mjs --bump major",
    "publish:dry": "node scripts/publish.mjs --dry-run --bump patch",
    "e2e": "ng e2e"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/schematics": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@cngxjs/compodocx": "^0.0.4",
    "@floating-ui/dom": "^1.7.6",
    "@playwright/test": "1.59.1",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.4",
    "http-server": "^14.1.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "playwright-ng-schematics": "^21.0.9",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.8"
  }
}