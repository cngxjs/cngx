{
  "compilerOptions": {
    "importHelpers": true,
    "baseUrl": "./",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "declaration": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "paths": {
      "@cngx/ui": ["projects/ui/src/index.ts"],
      "@cngx/data-display": ["projects/ui/data-display/src/index.ts"],
      "@cngx/layout": ["projects/ui/layout/src/index.ts"],
      "@cngx/grid": ["projects/ui/grid/src/index.ts"],
      "@cngx/forms": ["projects/ui/forms/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
