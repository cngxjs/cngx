{
  "compilerOptions": {
    "importHelpers": true,
    "baseUrl": "./",
    "module": "nodenext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "declaration": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "paths": {
      "@cngx/common": ["projects/common/src/index.ts"],
    }
  },
  "exclude": ["node_modules", "tmp"]
}
