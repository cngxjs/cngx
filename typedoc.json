{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "projects/utils/src/public-api.ts",
    "projects/utils/rxjs-interop/public-api.ts",
    "projects/core/src/public-api.ts",
    "projects/core/tokens/public-api.ts",
    "projects/core/utils/public-api.ts",
    "projects/forms/src/public-api.ts",
    "projects/forms/controls/public-api.ts",
    "projects/forms/validators/public-api.ts",
    "projects/ui/src/public-api.ts",
    "projects/ui/layout/public-api.ts",
    "projects/ui/overlay/public-api.ts",
    "projects/common/src/public-api.ts",
    "projects/data-display/src/public-api.ts",
    "projects/data-display/treetable/public-api.ts"
  ],
  "out": "docs",
  "name": "cngx Documentation",
  "readme": "README.md",
  "lang": "en",
  "disableSources": false,
  "tsconfig": "tsconfig.doc.json",
  "excludePrivate": true,
  "excludeProtected": true,
  "theme": "default",
  "plugin": [],
  "validation": {
    "notExported": true,
    "invalidLink": true
  }
}
